root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{java,kt}]
indent_size = 4
end_of_line = lf

[*.{cs,razor,cshtml}]
indent_size = 4
end_of_line = crlf

[*.{md,mdx}]
trim_trailing_whitespace = false
indent_size = 4

[*.ps1]
charset = utf-8-bom

# FOR WINDOWS
[*.{cmd,bat}]
end_of_line = crlf
